# ─────────────────────────────────────────────────────────────────────────────
# Analytics Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Keycloak / SSO ────────────────────────────────────────────────────────────
# URL where Keycloak is running (no trailing slash)
KEYCLOAK_SERVER_URL=http://localhost:8080

# Realm name configured in Keycloak
KEYCLOAK_REALM=master

# Client ID created in Keycloak for this app
KEYCLOAK_CLIENT_ID=analytics-dashboard

# Client Secret (from Keycloak → Client → Credentials tab)
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Keycloak admin credentials (master realm admin)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Optional: override auto-built discovery URL
# KEYCLOAK_DISCOVERY_URL=http://localhost:8080/realms/master/.well-known/openid-configuration

# Set to "true" to reject /api/* requests that have no valid Bearer token
KEYCLOAK_ENFORCE_API_AUTH=false

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics_dashboard

# Optional: override the full DB URL (takes precedence over POSTGRES_* above)
# WMS_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM / AI ─────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5-coder:7b
LLM_SUMMARY_MODEL=llama3.2:3b

# ── Django ────────────────────────────────────────────────────────────────────
# SECRET_KEY=your-django-secret-key-here
# DEBUG=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set to empty string when the frontend is served by Django (same origin).
# Set to the Django backend URL when running Vite dev server separately.
VITE_API_URL=
