# Copy to backend/.env or use project root .env (settings loads both).

# Option A — individual vars (password may contain @; no manual encoding)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Option B — full URLs (encode @ in password as %40)
# WMS_DATABASE_URL=postgresql://postgres:pass%40word@localhost:5432/analytics_dashboard
# DR_DATABASE_URL=postgresql://postgres:pass%40word@localhost:5432/analytics_dashboard

# DR app schema search: use "public" for a new local DB
DR_DATABASE_SEARCH_PATH=public

ENABLE_BACKGROUND_SCHEDULER=false
